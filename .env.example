# Update with your local PostgreSQL credentials
DATABASE_URL="postgresql://postgres:password@localhost:5432/tmci_ops?schema=public"
JWT_ACCESS_SECRET="tmci-access-secret-change-in-production"
JWT_REFRESH_SECRET="tmci-refresh-secret-change-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3000
API_PREFIX="api/v1"
CORS_ORIGIN="http://localhost:5173"
S3_BUCKET="tmci-operations"
S3_REGION="ap-south-1"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
